# gguf-serve environment variables
# Copy this file to .env and edit as needed.
# All variables are optional — gguf_serve.py has sensible defaults.

# Path to your GGUF model file (required when not using --model CLI flag)
GGUF_MODEL_PATH=./models/your-model.gguf

# Host to bind the Flask server on (default: 127.0.0.1)
GGUF_HOST=127.0.0.1

# Port to listen on (default: 8000)
GGUF_PORT=8000

# Context window size in tokens (default: 2048)
GGUF_N_CTX=2048

# Number of CPU threads used for inference (default: 4)
GGUF_N_THREADS=4

# Number of model layers to offload to GPU; 0 = CPU only (default: 0)
GGUF_N_GPU_LAYERS=0

# Default maximum tokens to generate per request (default: 256)
GGUF_MAX_TOKENS=256

# Default sampling temperature (default: 0.7)
GGUF_TEMPERATURE=0.7

# Set to 1 to start in mock mode — no GGUF file required, useful for testing (default: 0)
GGUF_MOCK_MODE=0

# Logging verbosity: DEBUG, INFO, WARNING, ERROR (default: INFO)
GGUF_LOG_LEVEL=INFO

# Rate limit: max requests per minute per IP address; 0 = disabled (default: 0)
GGUF_RATE_LIMIT=0

# Mock embedding vector dimension returned by /v1/embeddings (default: 384)
GGUF_EMBED_DIM=384

# Set to 1 to log every request with method, path, status, and latency (default: 0)
GGUF_LOG_REQUESTS=0

# Nucleus sampling top-p (default: 0.95)
GGUF_TOP_P=0.95

# Top-k sampling (default: 40)
GGUF_TOP_K=40

# Random seed for reproducible outputs; -1 = random (default: -1)
GGUF_SEED=-1

# Directory where demo.py writes output files (default: outputs)
GGUF_OUTPUTS_DIR=outputs
